---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Privacy Policy | JK.com" noIndex={true}>
  <div class="section-container section-pad">
    <div class="prose mx-auto" aria-label="Privacy policy">
      <h1>Privacy Policy</h1>
      <p class="text-sm" style="color: var(--color-text-ghost);">Last updated: April 2026</p>

      <h2>What we collect</h2>
      <p>JK.com collects minimal data: contact form submissions (name, email, message) and standard
      Cloudflare Web Analytics (page views, referrers — no cookies, no cross-site tracking).</p>

      <h2>How we use it</h2>
      <p>Contact form data is used solely to respond to your inquiry. Analytics data is used in aggregate
      to understand site usage. We do not sell, share, or monetize any data.</p>

      <h2>Cloudflare Analytics</h2>
      <p>This site uses <a href="https://www.cloudflare.com/web-analytics/" target="_blank" rel="noopener">
      Cloudflare Web Analytics</a> — a privacy-first analytics tool that does not use cookies and
      does not track individuals across sites.</p>

      <h2>Contact</h2>
      <p>Questions? Email <a href="mailto:jayson.knight@jaysonknight.com">jayson.knight@jaysonknight.com</a></p>
    </div>
  </div>
</BaseLayout>
