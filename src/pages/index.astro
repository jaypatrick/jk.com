---
// index.astro — JK.com homepage
// Astro 6 SSR + Cloudflare Workers — composing all Svelte sections
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/sections/Hero.svelte';
import About from '../components/sections/About.svelte';
import Services from '../components/sections/Services.svelte';
import Portfolio from '../components/sections/Portfolio.svelte';
import RssFeed from '../components/sections/RssFeed.svelte';
import Contact from '../components/sections/Contact.svelte';

// Cloudflare runtime locals — available in SSR
const { runtime } = Astro.locals;
// const env = runtime?.env; // Access bindings: env.DB, env.CACHE, etc.
---

<BaseLayout
  title="JK.com | AI Engineering, Cloud Architecture & Consulting — Jayson Knight"
  description="Jayson Knight — AI Engineer & Solutions Architect specializing in Anthropic Claude, agentic systems, Microsoft Azure, Cloudflare AI platforms, Rust/WASM, TypeScript/Deno, and .NET. 20+ years building enterprise software that scales. Based in Charlotte, NC."
>
  <!-- Hero: full-screen "THIS. IS. JK.com" -->
  <Hero client:load />

  <!-- About: who I am, expertise, philosophy -->
  <About client:visible />

  <!-- Services: technical + creative tabs -->
  <Services client:visible />

  <!-- Portfolio: case studies + clients -->
  <Portfolio client:visible />

  <RssFeed client:visible feedUrl="https://bloqr.jaysonknight.com/rss.xml" maxItems={5} />

  <!-- Contact: form + phone + location -->
  <Contact client:visible />
</BaseLayout>
