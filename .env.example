# Copy this file to .env and fill in values
# For Cloudflare bindings, use wrangler secret put or .dev.vars for local dev

# Cloudflare Web Analytics token (get from Cloudflare Dashboard → Analytics → Web Analytics)
CLOUDFLARE_ANALYTICS_TOKEN=your_token_here

# Contact form — Resend/Email service API key for sending contact form submissions
# RESEND_API_KEY=your_resend_api_key

# Site
SITE_URL=https://jaysonknight.com

# Blog RSS feed URL (used as fallback when no ?url= query param is passed to /api/rss)
RSS_FEED_URL=https://blog.jaysonknight.com/feed/
